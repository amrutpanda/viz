  <equality>
        <connect name="kinematic_link" active="true" body1="forearm_link" body2="elbow_link" anchor="0 0 4" />
<!--         <connect name="dynamic_loop" active="true" body1="forearm_link" body2="elbow_link" anchor="0 0 4" />-->
  </equality>
  
