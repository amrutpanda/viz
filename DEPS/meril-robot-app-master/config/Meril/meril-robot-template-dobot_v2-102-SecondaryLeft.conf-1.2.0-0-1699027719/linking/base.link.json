        {
          "Source": {
            "Path": "root/AxesControl/axesLimiters/State%02d/active",
            "Index": 1
          },
          "Destination": {
            "Path": "root/Logic/actuatorLimitersActive"
          }
        }
      ]
    },
    {
      "Name": "Window Detectors and Main Control Loop",
      "SystemMode": "All",
      "Links": [
        {
          "Source": {
            "Path": "root/ManipulatorControl/manipulabilityDetector/state"
          },
          "Destination": {
            "Path": "root/Logic/actualManipulabilityDetector"
          }
        }
      ]
    },
    {
      "Name": "Drive --> Logic",
      "SystemMode": "All",
      "Links": [
        {
          "Source": {
            "Path": "root/DriveLogic/driveHasNoError"
          },
          "Destination": {
            "Path": "root/Logic/driveHasNoError"
          }
        },
        {
          "Source": {
            "Path": "root/Logic/driveCommand"
          },
          "Destination": {
            "Path": "root/DriveLogic/driveCommandAll"
          }
        },
        {
          "Source": {
            "Path": "root/Logic/driveMode"
          },
          "Destination": {
            "Path": "root/DriveLogic/driveModeAll"
          }
        }
      ]
    },
    {
      "Name": "Ecat --> Logic",
      "SystemMode": "All",
      "Links": [
        {
          "Source": {
            "Path": "root/Ethercat/GCC/error"
          },
          "Destination": {
            "Path": "root/Logic/:busToState/ecat_domain_error",
            "Index": 0,
            "Length": 1
          }
        },
        {
          "Source": {
            "Path": "root/Ethercat/Robot/error"
          },
          "Destination": {
            "Path": "root/Logic/:busToState/ecat_domain_error",
            "Index": 1,
            "Length": 1
          }
        }
      ]
    },
    {
      "Name": "From Logic To Control",
      "SystemMode": "All",
      "Links": [
        {
          "Source": {
            "Path": "root/Logic/:stateToCtrl"
          },
          "Destination": {
            "Path": "root/ManipulatorControl/:fromState"
          }
        },
        {
          "Source": {
            "Path": "root/Logic/:modeToCtrl"
          },
          "Destination": {
            "Path": "root/ManipulatorControl/:fromMode"
          }
        }
      ]
    },
    {
      "Name": "From Control To Logic",
      "SystemMode": "All",
      "Links": [
        {
          "Source": {
            "Path": "root/ManipulatorControl/:toMode"
          },
          "Destination": {
            "Path": "root/Logic/:ctrlToMode"
          }
        }
      ]
    },
    {
      "Name": "From Logic To Actuator Control",
      "SystemMode": "All",
      "Links": [
        {
          "Source": {
            "Path": "root/Logic/:stateToCtrl"
          },
          "Destination": {
            "Path": "root/AxesControl/:fromState"
          }
        },
        {
          "Source": {
            "Path": "root/Logic/:modeToCtrl"
          },
          "Destination": {
            "Path": "root/AxesControl/:fromMode"
          }
        }
      ]
    },
    {
      "Name": "From Actuator Control To Logic",
      "SystemMode": "All",
      "Links": [
        {
          "Source": {
            "Path": "root/AxesControl/:toState"
          },
          "Destination": {
            "Path": "root/Logic/:ctrlToState"
          }
        }
      ]
    },
    {
      "Name": "Between Actuator Control and Robot Control",
      "SystemMode": "All",
      "Enable": true,
      "Links": [
        {
          "Source": {
            "Path": "root/ManipulatorControl/idJointTorque/actual/gravity"
          },
          "Destination": {
            "Path": "root/AxesControl/axesTorqueInputs"
          }
        },
        {
          "Source": {
            "Path": "root/AxesControl/axesPositionsActual"
          },
          "Destination": {
            "Path": "root/ManipulatorControl/jointPositionsActual"
          }
