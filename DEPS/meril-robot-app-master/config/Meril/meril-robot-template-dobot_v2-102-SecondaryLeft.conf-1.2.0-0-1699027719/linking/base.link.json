        {
          "Source": {
            "Path": "root/AxesControl/actuatorControlLoops/actuatorControlLoop%02d/positionWindowDetector/state",
            "Index": 1
          },
          "Destination": {
            "Path": "root/Logic/positionDetectors"
          }
        },
        {
          "Source": {
            "Path": "root/AxesControl/actuatorControlLoops/actuatorControlLoop%02d/velocityWindowDetector/state",
            "Index": 1
          },
          "Destination": {
            "Path": "root/Logic/velocityDetectors"
          }
