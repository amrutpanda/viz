        {
          "Source": {
            "Path": "root/AxesControl/actuatorControlLoops/actuatorControlLoop%02d/accelerationWindowDetector/state",
            "Index": 1
          },
          "Destination": {
            "Path": "root/Logic/accelerationDetectors"
          }
