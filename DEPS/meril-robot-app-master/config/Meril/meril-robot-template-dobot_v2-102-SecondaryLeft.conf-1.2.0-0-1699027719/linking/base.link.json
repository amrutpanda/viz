        {
          "Source": {
            "Path": "root/AxesControl/actuatorControlLoops/actuatorControlLoop%02d/torqueWindowDetector/state",
            "Index": 1
          },
          "Destination": {
            "Path": "root/Logic/torqueDetectors"
