          }
        },
        {
          "Source": {
            "Path": "root/DriveLogic/driveEnabled"
          },
          "Destination": {
            "Path": "root/AxesControl/actuatorControlLoops/actuatorControlLoop%02d/driveIsEnabled",
            "Index": 1
