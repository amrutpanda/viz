        {
          "Source": {
            "Path": "root/AxesControl/axesAccelerationsActual"
          },
          "Destination": {
            "Path": "root/ManipulatorControl/jointAccelerationsActual"
          }
        },
        {
          "Source": {
            "WrongPath_": "root/AxesControl/actuatorControlLoops/actuatorTorquesActual",
            "Path": "root/AxesControl/sensorTorquesActual"
          },
          "Destination": {
            "Path": "root/ManipulatorControl/jointTorquesActual"
          }
        },
        {
          "Source": {
            "Path": "root/AxesControl/axesPositionsReference"
          },
          "Destination": {
            "Path": "root/ManipulatorControl/jointPositionsLimitedReference"
          }
        },
        {
          "Source": {
            "Path": "root/AxesControl/axesVelocitiesReference"
          },
          "Destination": {
            "Path": "root/ManipulatorControl/jointVelocitiesLimitedReference"
          }
        },
        {
          "Source": {
            "Path": "root/AxesControl/axesAccelerationsReference"
          },
          "Destination": {
            "Path": "root/ManipulatorControl/jointAccelerationsLimitedReference"
          }
        },
        {
          "Source": {
            "Path": "root/AxesControl/allDrivesDisabled"
          },
          "Destination": {
            "Path": "root/ManipulatorControl/allDrivesDisabled"
          }
        },
        {
          "Source": {
            "Path": "root/ManipulatorControl/jointPositionsTarget"
          },
          "Destination": {
            "Path": "root/AxesControl/axesPositionInputs"
          }
        }
      ]
    },
    {
      "Name": "Simulation General",
      "SystemMode": "Simulation",
      "Links": [
        {
          "Source": {
            "Path": "root/DriveLogic/driveEnabled"
          },
          "Destination": {
            "Path": "root/Simulator/driveOn"
          }
        },
        {
          "Source": {
            "Path": "root/AxesControl/actuatorControlLoops/actuatorControlLoop%02d/positionTransformation/transducer/referenceHardwareSide",
            "Index": 1
          },
          "Destination": {
            "Path": "root/Simulator/positionValueInit"
          }
        }
      ]
    },
    {
      "Name": "Simulation",
      "SystemMode": "Simulation",
      "SetParameters": [
        {
          "Path": "root/CollisionDetectors/CollisionDetector%02d/collisionDetector/disable",
          "Value": true,
          "Index": 1
        },
        {
          "Path": "root/Ethercat/GCC/01-EL6910-01/Outputs/oSTONotActive",
          "Value": true
        },
        {
          "Path": "root/Ethercat/Robot/Axis-06/Out/5000_01/Bit1",
          "Value": 1
        },
        {
          "Path": "root/Ethercat/Robot/Axis-06/Out/5000_01/Bit4",
          "Value": 1
        }
      ]
    }
  ]
